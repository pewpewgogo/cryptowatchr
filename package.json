{
  "name": "cryptowatchr",
  "version": "0.1.0",
  "private": true,
  "description": "Telegram bot for personal crypto watchlists and non-spammy price alerts.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "npm run build && node --watch dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "ioredis": "^5.4.1",
    "grammy": "^1.43.0",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
