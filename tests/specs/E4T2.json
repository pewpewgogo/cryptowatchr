[
  {
    "name": "/summary command shows off state",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "onboard:skip", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "text": "/summary" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "*Morning Summary*\n\nStatus: Off\n\nTurn on morning summary to receive a daily report of your watched coins.",
              "parse_mode": "Markdown",
              "reply_markup": {
                "inline_keyboard": [
                  [{ "text": "Turn On Summary", "callback_data": "settings:summary:enable" }],
                  [{ "text": "Back to menu", "callback_data": "menu:back" }]
                ]
              }
            }
          }
        ]
      }
    ]
  },
  {
    "name": "settings menu shows morning summary off",
    "steps": [
      {
        "send": { "text": "/start" },
