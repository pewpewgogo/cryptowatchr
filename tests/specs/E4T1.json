[
  {
    "name": "/price with empty watchlist shows empty message",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "onboard:skip", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "text": "/price" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Your watchlist is empty.\n\nUse the Add Coin menu or type a ticker to start building your watchlist."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "/price with unknown ticker shows error",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "onboard:skip", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "text": "/price XYZ" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "\"XYZ\" is not a recognized ticker. Try a known ticker like BTC, ETH, or SOL."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "menu:price with empty watchlist shows empty message",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "onboard:skip", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "menu:price", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": {
              "text": "Your watchlist is empty.\n\nUse the Add Coin menu or type a ticker to start building your watchlist."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "/price with a coin added to watchlist attempts fetch",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "onboard:tz:UTC+3", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "onboard:done", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "menu:add", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "watchlist:coin:BTC", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "text": "/price" },
        "expect": [{ "method": "sendMessage" }]
      }
    ]
  },
  {
    "name": "menu:price with a coin added to watchlist attempts fetch",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "onboard:tz:UTC+3", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "onboard:done", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "menu:add", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "watchlist:coin:BTC", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "menu:price", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      }
    ]
  }
]
