  {
    "name": "invalid percentage shows validation error",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "onboard:tz:UTC+3", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "onboard:done", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "menu:alerts", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "alert:type:percent", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "alert:pcoin:BTC", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "text": "not a number" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Please enter a valid positive percentage (e.g. 5 for 5%).",
              "reply_markup": {
                "inline_keyboard": [
                  [{ "text": "Back", "callback_data": "alert:pct:back:coin" }],
                  [{ "text": "Cancel", "callback_data": "alert:cancel" }]
                ]
              }
            }
          }
        ]
      },
      {
        "send": { "text": "0" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Please enter a valid positive percentage (e.g. 5 for 5%)."
            }
          }
        ]
      },
      {
        "send": { "text": "-5" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Please enter a valid positive percentage (e.g. 5 for 5%)."
            }
          }
        ]
      }
    ]
