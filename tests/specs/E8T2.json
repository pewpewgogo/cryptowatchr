[
  {
    "name": "watchlist persists after navigating away and back",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "onboard:skip", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "menu:add", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": {
              "text": "Add a coin to your watchlist:\n\nChoose from the common coins below or enter a custom ticker.",
              "reply_markup": {
                "inline_keyboard": [
                  [{ "text": "Bitcoin (BTC)", "callback_data": "watchlist:coin:BTC" }],
                  [{ "text": "Ethereum (ETH)", "callback_data": "watchlist:coin:ETH" }],
                  [{ "text": "Toncoin (TON)", "callback_data": "watchlist:coin:TON" }],
                  [{ "text": "Custom ticker", "callback_data": "watchlist:coin:custom" }],
                  [{ "text": "Back to menu", "callback_data": "watchlist:back" }]
                ]
              }
            }
          }
        ]
      },
      {
        "send": { "callback": "watchlist:coin:BTC", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": {
              "text": "BTC added to your watchlist.\n\nUse the menu to manage your watchlist or create alerts for your coins.",
              "reply_markup": {
                "inline_keyboard": [
                  [
                    { "text": "Add Coin", "callback_data": "menu:add" },
                    { "text": "My Watchlist", "callback_data": "menu:watchlist" }
                  ],
                  [
                    { "text": "Create Alert", "callback_data": "menu:alerts" },
                    { "text": "My Alerts", "callback_data": "menu:myalerts" }
                  ],
                  [
                    { "text": "Price Check", "callback_data": "menu:price" },
                    { "text": "Settings", "callback_data": "menu:settings" }
                  ],
                  [
                    { "text": "Help", "callback_data": "menu:help" }
                  ]
                ]
              }
            }
          }
        ]
      },
      {
        "send": { "callback": "menu:settings", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "menu:watchlist", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": {
              "text": "Your watchlist:\n\u2022 BTC\n\nTap Remove to take a coin off your list.",
              "reply_markup": {
                "inline_keyboard": [
                  [{ "text": "Remove BTC", "callback_data": "watchlist:remove:BTC" }],
                  [{ "text": "Back to menu", "callback_data": "menu:back" }]
                ]
              }
            }
          }
        ]
      }
    ]
  },
  {
    "name": "watchlist survives /start restart",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "onboard:skip", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "menu:add", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "watchlist:coin:ETH", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "text": "/start" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "reply_markup": {
                "inline_keyboard": [
                  [
                    { "text": "UTC-8 (PST)", "callback_data": "onboard:tz:UTC-8" },
                    { "text": "UTC-5 (EST)", "callback_data": "onboard:tz:UTC-5" }
                  ],
                  [
                    { "text": "UTC+0 (GMT)", "callback_data": "onboard:tz:UTC+0" },
                    { "text": "UTC+3 (MSK)", "callback_data": "onboard:tz:UTC+3" }
                  ],
                  [
                    { "text": "UTC+8 (CST)", "callback_data": "onboard:tz:UTC+8" },
                    { "text": "Skip for now", "callback_data": "onboard:skip" }
                  ]
                ]
              }
            }
          }
        ]
      },
      {
        "send": { "callback": "onboard:skip", "messageId": 2 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "menu:watchlist", "messageId": 2 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": {
              "text": "Your watchlist:\n\u2022 ETH\n\nTap Remove to take a coin off your list.",
              "reply_markup": {
                "inline_keyboard": [
                  [{ "text": "Remove ETH", "callback_data": "watchlist:remove:ETH" }],
                  [{ "text": "Back to menu", "callback_data": "menu:back" }]
                ]
              }
            }
          }
        ]
      }
    ]
  },
  {
    "name": "alert rule persists after navigating away and back",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "onboard:skip", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "menu:alerts", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": {
              "text": "Choose the type of alert you want to create:",
              "reply_markup": {
                "inline_keyboard": [
                  [{ "text": "Threshold Alert", "callback_data": "alert:type:threshold" }],
                  [{ "text": "Percent Alert", "callback_data": "alert:type:percent" }],
                  [{ "text": "Back to menu", "callback_data": "menu:back" }]
                ]
              }
            }
          }
        ]
      },
      {
        "send": { "callback": "alert:type:threshold", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": {
              "text": "Select a coin for your threshold alert:",
              "reply_markup": {
                "inline_keyboard": [
                  [{ "text": "Bitcoin (BTC)", "callback_data": "alert:coin:BTC" }],
                  [{ "text": "Ethereum (ETH)", "callback_data": "alert:coin:ETH" }],
                  [{ "text": "Toncoin (TON)", "callback_data": "alert:coin:TON" }],
                  [{ "text": "Custom ticker", "callback_data": "alert:coin:custom" }],
                  [{ "text": "Back", "callback_data": "alert:back:type" }]
                ]
              }
            }
          }
        ]
      },
      {
        "send": { "callback": "alert:coin:BTC", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": {
              "text": "BTC: When should this threshold alert fire?",
              "reply_markup": {
                "inline_keyboard": [
                  [{ "text": "Above", "callback_data": "alert:dir:above" }],
                  [{ "text": "Below", "callback_data": "alert:dir:below" }],
                  [{ "text": "Back", "callback_data": "alert:back:coin" }]
                ]
              }
            }
          }
        ]
      },
      {
        "send": { "callback": "alert:dir:above", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": {
              "text": "Enter the price threshold in USD for:\n\nBTC above\n\nExample: if you enter 60000, you will be alerted when BTC goes above $60,000.",
              "reply_markup": {
                "inline_keyboard": [
                  [{ "text": "Cancel", "callback_data": "alert:cancel" }]
                ]
              }
            }
          }
        ]
      },
      {
        "send": { "text": "100000" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Alert created: BTC above $100,000.00",
              "reply_markup": {
                "inline_keyboard": [
                  [
                    { "text": "Add Coin", "callback_data": "menu:add" },
                    { "text": "My Watchlist", "callback_data": "menu:watchlist" }
                  ],
                  [
                    { "text": "Create Alert", "callback_data": "menu:alerts" },
                    { "text": "My Alerts", "callback_data": "menu:myalerts" }
                  ],
                  [
                    { "text": "Price Check", "callback_data": "menu:price" },
                    { "text": "Settings", "callback_data": "menu:settings" }
                  ],
                  [
                    { "text": "Help", "callback_data": "menu:help" }
                  ]
                ]
              }
            }
          }
        ]
      },
      {
        "send": { "callback": "menu:settings", "messageId": 2 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "menu:myalerts", "messageId": 2 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": {
              "text": "Your alerts:\n1. BTC above $100,000.00\n\nTap Edit to modify or Delete to remove an alert."
            }
          }
        ]
      }
    ]
  },
